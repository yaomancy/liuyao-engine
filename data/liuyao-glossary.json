{
  "_meta": {
    "用途": "六爻术语可读层语料——爻位注解与断卦术语解释的单一来源。",
    "简繁": "只维护简体一份；如需繁体可经 OpenCC 就地转换。",
    "宪法": "只写【含义/取象】固有属性，不含对任何具体卦/事的吉凶宜忌判断（判断只属于解读的专业断卦层）；非 LLM 生成，依《卜筮正宗》《增删卜易》通行术语。",
    "key约定": "按卦象 JSON 契约的简体枚举值做 key（六亲/六神/旺衰/世应/动爻类型）。",
    "版本": "2",
    "英文说明": "术语与卦名附拼音 + 通用英文名(64卦英文名依 Wilhelm/Baynes 译本)，仅作国际检索指针，非权威释义；释义性古典内容不英译。"
  },
  "六亲": {
    "父母": {
      "一句": "生我者为父母——主长辈、文书、房屋、车舟、学业，凡庇护我、由上而来之事。",
      "用神": "问文书、学业、房产、车辆、长辈、消息时，以父母为用神。",
      "拼音": "fùmǔ",
      "en": "parent line (resources/documents/elders)"
    },
    "兄弟": {
      "一句": "比和者为兄弟——主同辈、朋友、同事，亦为劫财夺财之神。",
      "用神": "问兄弟、朋友、同辈、合伙、竞争对手时，以兄弟为用神。",
      "拼音": "xiōngdì",
      "en": "sibling line (peers/rivals)"
    },
    "子孙": {
      "一句": "我生者为子孙——主子女、晚辈、医药、僧道，为解忧之福神，能克制官鬼。",
      "用神": "问子女、晚辈、求医问药、出行平安、避祸时，以子孙为用神。",
      "拼音": "zǐsūn",
      "en": "offspring line (children/relief/medicine)"
    },
    "妻财": {
      "一句": "我克者为妻财——主钱财、货物、薪资，于男亦主妻、女友。",
      "用神": "问钱财、求财、买卖货物、妻子、女友时，以妻财为用神。",
      "拼音": "qīcái",
      "en": "wealth line (money/wife)"
    },
    "官鬼": {
      "一句": "克我者为官鬼——主官职、功名、官非、疾病、鬼祟，于女亦主夫、男友。",
      "用神": "问工作、考试功名、官司、疾病、丈夫、男友时，以官鬼为用神。",
      "拼音": "guānguǐ",
      "en": "officer-ghost line (career/illness/husband)"
    }
  },
  "六神": {
    "青龙": {
      "一句": "六神之首，其象主喜庆、和合、酒色、正大光明之事。",
      "拼音": "qīnglóng",
      "en": "Azure Dragon"
    },
    "朱雀": {
      "一句": "其象主口舌、文书、信息、音讯、是非言语之事。",
      "拼音": "zhūquè",
      "en": "Vermilion Bird"
    },
    "勾陈": {
      "一句": "其象主田土、房产、牵连、迟滞、勾连不解之事。",
      "拼音": "gōuchén",
      "en": "Hooked Array (Kou Chen)"
    },
    "螣蛇": {
      "一句": "其象主虚惊、怪异、缠绕、忧疑、梦寐不安之事。",
      "拼音": "téngshé",
      "en": "Soaring Serpent"
    },
    "白虎": {
      "一句": "其象主刚猛、道路、疾病、丧服、血光金刃之事。",
      "拼音": "báihǔ",
      "en": "White Tiger"
    },
    "玄武": {
      "一句": "其象主暗昧、盗贼、暧昧、阴私、水事不明之事。",
      "拼音": "xuánwǔ",
      "en": "Black Tortoise"
    }
  },
  "旺衰": {
    "旺": {
      "一句": "与当月之气同类，当令最得气，力量最旺。",
      "拼音": "wàng",
      "en": "prosperous (in season)"
    },
    "相": {
      "一句": "得当月之气所生，次于旺，谓之相，得时之助。",
      "拼音": "xiàng",
      "en": "strong (supported by season)"
    },
    "休": {
      "一句": "去生当月之气（我生月令），气已泄退，谓之休。",
      "拼音": "xiū",
      "en": "resting (waning)"
    },
    "囚": {
      "一句": "去克当月之气（我克月令），反受其制，谓之囚。",
      "拼音": "qiú",
      "en": "trapped"
    },
    "死": {
      "一句": "被当月之气所克（月令克我），力量最弱，谓之死。",
      "拼音": "sǐ",
      "en": "dead (weakest)"
    }
  },
  "世应": {
    "世": {
      "一句": "世爻代表求测者自身、我方、此一端。",
      "拼音": "shì",
      "en": "self line"
    },
    "应": {
      "一句": "应爻与世相对，代表对方、他人、所测之事的彼一端。",
      "拼音": "yìng",
      "en": "other line"
    }
  },
  "动爻": {
    "老阳": {
      "一句": "重爻——阳极而动、将变为阴；标记此爻发动，事在变化之中。",
      "拼音": "lǎoyáng",
      "en": "old yang (moving)"
    },
    "老阴": {
      "一句": "交爻——阴极而动、将变为阳；标记此爻发动，事在变化之中。",
      "拼音": "lǎoyīn",
      "en": "old yin (moving)"
    }
  },
  "状态": {
    "旬空": {
      "一句": "该爻地支落在本旬的两个空亡之内——暂时不到位，常须待出空之日方才应事。",
      "拼音": "xúnkōng",
      "en": "void / empty branch"
    },
    "月破": {
      "一句": "被当月之气所冲——力量被冲破打折，谓之月破。",
      "拼音": "yuèpò",
      "en": "month-broken"
    },
    "日冲": {
      "一句": "被当日的日辰所冲——受日辰冲动、冲散。",
      "拼音": "rìchōng",
      "en": "day-clash"
    },
    "发动": {
      "一句": "此爻是动爻、正在变化，将生出变卦，可能回头生克。",
      "拼音": "fādòng",
      "en": "moving / active line"
    },
    "暗动": {
      "一句": "静爻被日辰冲而暗中发动——不显于卦面，却暗中起作用。",
      "拼音": "àndòng",
      "en": "hidden activation"
    }
  },
